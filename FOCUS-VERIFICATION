<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FOCUS — Vérification Billet</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:#F5F5F5;min-height:100vh;color:#1A1A1A}

/* ══ LOGIN ══ */
.login-screen{
  position:fixed;inset:0;background:#1A1A1A;
  display:flex;align-items:center;justify-content:center;
  z-index:999;padding:1.5rem;
}
.login-card{
  background:#fff;border-radius:20px;padding:2.5rem 2rem;
  width:100%;max-width:360px;text-align:center;
}
.login-logo{
  width:64px;height:64px;background:#FFC000;border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  font-size:32px;margin:0 auto 1.25rem;
}
.login-title{font-size:22px;font-weight:800;margin-bottom:.25rem}
.login-sub{font-size:13px;color:#999;margin-bottom:2rem;line-height:1.5}

/* PIN DIGITS */
.pin-display{
  display:flex;justify-content:center;gap:12px;margin-bottom:1.5rem;
}
.pin-dot{
  width:18px;height:18px;border-radius:50%;
  background:#E0E0E0;transition:all .2s;
}
.pin-dot.filled{background:#FFC000;transform:scale(1.15)}
.pin-dot.error{background:#EF4444;animation:shake .3s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-4px)}75%{transform:translateX(4px)}}

/* CLAVIER */
.pin-pad{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:1rem}
.pin-key{
  padding:16px;background:#F5F5F5;border:none;border-radius:12px;
  font-size:20px;font-weight:700;cursor:pointer;transition:all .15s;
  font-family:inherit;color:#1A1A1A;
}
.pin-key:hover{background:#FFF8E1;color:#FFC000}
.pin-key:active{transform:scale(.94)}
.pin-key.del{background:#FDECEA;color:#EF4444;font-size:16px}
.pin-key.del:hover{background:#EF4444;color:#fff}
.pin-key.empty{background:transparent;cursor:default}

.login-err{
  background:#FDECEA;color:#C0392B;border-radius:10px;
  padding:10px 14px;font-size:13px;margin-bottom:1rem;
  display:none;
}
.login-attempts{font-size:12px;color:#999;margin-top:.5rem}

/* Blocage temporaire */
.blocked-msg{
  background:#FFF8E1;border:2px solid #FFC000;border-radius:12px;
  padding:14px;font-size:13px;color:#5D4037;margin-bottom:1rem;
  display:none;text-align:center;
}

/* ══ APP ══ */
.app{display:none}
.header{
  background:#1A1A1A;padding:14px 20px;
  display:flex;align-items:center;justify-content:space-between;
}
.header-left{display:flex;align-items:center;gap:10px}
.header-logo{width:36px;height:36px;background:#FFC000;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px}
.header-title{font-size:15px;font-weight:700;color:#FFC000}
.header-sub{font-size:11px;color:rgba(255,255,255,.4);margin-top:1px}
.header-right{display:flex;align-items:center;gap:8px}
.badge-agent{background:#FFC000;color:#1A1A1A;font-size:10px;font-weight:800;padding:4px 10px;border-radius:100px;letter-spacing:1px}
.logout-btn{background:rgba(255,255,255,.1);border:none;color:rgba(255,255,255,.5);font-size:12px;font-family:inherit;padding:6px 10px;border-radius:8px;cursor:pointer;transition:.15s}
.logout-btn:hover{background:rgba(239,68,68,.2);color:#EF4444}

.container{max-width:500px;margin:0 auto;padding:1.25rem}

/* RESULT */
.result-valid{background:#fff;border:3px solid #22C55E;border-radius:20px;overflow:hidden;box-shadow:0 4px 24px rgba(34,197,94,.12);margin-bottom:1rem}
.result-valid .rh{background:#22C55E;padding:20px;text-align:center;color:#fff}
.result-invalid{background:#fff;border:3px solid #EF4444;border-radius:20px;overflow:hidden;box-shadow:0 4px 24px rgba(239,68,68,.12);margin-bottom:1rem}
.result-invalid .rh{background:#EF4444;padding:20px;text-align:center;color:#fff}
.result-expired{background:#fff;border:3px solid #F59E0B;border-radius:20px;overflow:hidden;box-shadow:0 4px 24px rgba(245,158,11,.12);margin-bottom:1rem}
.result-expired .rh{background:#F59E0B;padding:20px;text-align:center;color:#fff}
.rh-ico{font-size:48px;margin-bottom:8px}
.rh-title{font-size:22px;font-weight:800;margin-bottom:4px}
.rh-sub{font-size:14px;opacity:.85}

.ticket-rows{padding:4px 0}
.tr{display:flex;justify-content:space-between;align-items:flex-start;padding:12px 18px;border-bottom:1px solid #F0F0F0;font-size:14px;gap:12px}
.tr:last-child{border:none}
.tr .k{color:#999;flex-shrink:0;font-size:13px}
.tr .v{font-weight:600;text-align:right}
.tr .v.gold{color:#FFC000}
.tr .v.green{color:#22C55E}
.tr .v.red{color:#EF4444}
.tr .v.orange{color:#F59E0B}

/* SCAN BOX */
.scan-box{background:#fff;border:2px solid #E0E0E0;border-radius:16px;padding:1.25rem;margin-bottom:1rem}
.scan-title{font-size:16px;font-weight:700;margin-bottom:.4rem}
.scan-sub{font-size:13px;color:#999;margin-bottom:1rem;line-height:1.5}
.fi{width:100%;padding:13px 15px;background:#F5F5F5;border:2px solid #E0E0E0;border-radius:11px;font-size:14px;font-family:inherit;outline:none;transition:.2s}
.fi:focus{border-color:#FFC000;background:#FFF8E1}
.btn-or{display:flex;align-items:center;justify-content:center;width:100%;padding:14px;background:#FFC000;color:#1A1A1A;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;margin-top:10px;font-family:inherit;transition:.15s}
.btn-or:hover{background:#FFD333}
.btn-out{display:flex;align-items:center;justify-content:center;width:100%;padding:13px;background:transparent;color:#1A1A1A;border:2px solid #E0E0E0;border-radius:12px;font-size:14px;font-weight:500;cursor:pointer;margin-top:8px;font-family:inherit;transition:.15s}
.btn-out:hover{border-color:#FFC000}

.aerr{background:#FDECEA;border:1.5px solid rgba(192,57,43,.2);color:#C0392B;border-radius:11px;padding:12px 14px;font-size:13px;margin-bottom:1rem;display:none;line-height:1.5}

.empty-state{text-align:center;padding:2.5rem 1rem;color:#999}
.empty-ico{font-size:56px;margin-bottom:1rem;opacity:.35}
.empty-title{font-size:17px;font-weight:700;color:#1A1A1A;margin-bottom:.5rem}
.empty-sub{font-size:13px;line-height:1.6}

.ts{font-size:11px;color:#bbb;text-align:center;padding:8px;font-family:'Courier New',monospace}

/* Session info */
.session-bar{
  background:#FFF8E1;border-bottom:1px solid #FFD54F;
  padding:8px 20px;display:flex;align-items:center;justify-content:space-between;
  font-size:12px;color:#5D4037;
}
.session-dot{width:8px;height:8px;background:#22C55E;border-radius:50%;display:inline-block;margin-right:6px;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
</style>
</head>
<body>

<!-- ══ ÉCRAN DE CONNEXION ══ -->
<div class="login-screen" id="login-screen">
  <div class="login-card">
    <div class="login-logo">🔍</div>
    <div class="login-title">FOCUS Vérification</div>
    <div class="login-sub">Accès réservé à l'équipe FOCUS.<br>Saisissez votre code PIN agent.</div>

    <div class="blocked-msg" id="blocked-msg"></div>
    <div class="login-err" id="login-err"></div>

    <div class="pin-display" id="pin-display">
      <div class="pin-dot" id="d0"></div>
      <div class="pin-dot" id="d1"></div>
      <div class="pin-dot" id="d2"></div>
      <div class="pin-dot" id="d3"></div>
    </div>

    <div class="pin-pad">
      <button class="pin-key" onclick="pressKey('1')">1</button>
      <button class="pin-key" onclick="pressKey('2')">2</button>
      <button class="pin-key" onclick="pressKey('3')">3</button>
      <button class="pin-key" onclick="pressKey('4')">4</button>
      <button class="pin-key" onclick="pressKey('5')">5</button>
      <button class="pin-key" onclick="pressKey('6')">6</button>
      <button class="pin-key" onclick="pressKey('7')">7</button>
      <button class="pin-key" onclick="pressKey('8')">8</button>
      <button class="pin-key" onclick="pressKey('9')">9</button>
      <button class="pin-key empty"></button>
      <button class="pin-key" onclick="pressKey('0')">0</button>
      <button class="pin-key del" onclick="deleteKey()">⌫</button>
    </div>

    <div class="login-attempts" id="attempts-txt"></div>
  </div>
</div>

<!-- ══ APPLICATION ══ -->
<div class="app" id="app">
  <div class="header">
    <div class="header-left">
      <div class="header-logo">🔍</div>
      <div>
        <div class="header-title">FOCUS — Vérification</div>
        <div class="header-sub">Contrôle des billets</div>
      </div>
    </div>
    <div class="header-right">
      <div class="badge-agent">AGENT</div>
      <button class="logout-btn" onclick="logout()">Quitter</button>
    </div>
  </div>

  <div class="session-bar">
    <div><span class="session-dot"></span>Session active</div>
    <div id="session-time"></div>
  </div>

  <div class="container">
    <div id="result-area">
      <div class="empty-state">
        <div class="empty-ico">🎫</div>
        <div class="empty-title">Prêt à vérifier</div>
        <div class="empty-sub">Scannez le QR code d'un billet FOCUS<br>ou collez les données ci-dessous</div>
      </div>
    </div>

    <div class="scan-box">
      <div class="scan-title">📋 Vérification manuelle</div>
      <div class="scan-sub">Collez les données du QR code ou saisissez la référence du billet</div>
      <div id="err-box" class="aerr"></div>
      <input class="fi" id="ref-input" placeholder="FOCUS-BK-20260610-XXXX ou données QR" oninput="clearErr()">
      <button class="btn-or" onclick="verifyManual()">🔍 Vérifier ce billet</button>
      <button class="btn-out" onclick="clearResult()">🔄 Nouveau contrôle</button>
    </div>

    <div class="ts" id="ts"></div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════
//  PIN — Codes agents FOCUS
//  À modifier directement ici pour changer les codes
// ══════════════════════════════════════════════
const AGENT_PINS = [
  '0001',   // Agent principal
  '0002',   // Agent 2 — À CHANGER en production
  '0003',   // Agent 3
];

// Durée session : 8 heures
const SESSION_DURATION_MS = 8 * 60 * 60 * 1000;
// Blocage après 5 tentatives : 10 minutes
const MAX_ATTEMPTS = 5;
const BLOCK_MS     = 10 * 60 * 1000;

let pinEntry    = '';
let attempts    = 0;
let blockedUntil= null;
let sessionStart= null;
let sessionTimer= null;

// ── Vérifier session existante
(function checkSession(){
  const saved = sessionStorage.getItem('focus_agent_session');
  if(saved){
    const s = JSON.parse(saved);
    if(Date.now() - s.start < SESSION_DURATION_MS){
      sessionStart = s.start;
      showApp();
      return;
    }
  }
  // Vérifier blocage
  const block = localStorage.getItem('focus_block');
  if(block){
    const until = parseInt(block);
    if(Date.now() < until){
      blockedUntil = until;
      showBlock();
    } else {
      localStorage.removeItem('focus_block');
      localStorage.removeItem('focus_attempts');
    }
  }
  attempts = parseInt(localStorage.getItem('focus_attempts')||'0');
  updateAttemptsLabel();
})();

// ── Saisie PIN
function pressKey(k){
  if(blockedUntil && Date.now() < blockedUntil){ showBlock(); return; }
  if(pinEntry.length >= 4) return;
  pinEntry += k;
  updateDots();
  if(pinEntry.length === 4) setTimeout(checkPin, 200);
}

function deleteKey(){
  pinEntry = pinEntry.slice(0,-1);
  updateDots();
  hideErr();
}

function updateDots(){
  for(let i=0;i<4;i++){
    const d = document.getElementById('d'+i);
    d.classList.toggle('filled', i < pinEntry.length);
    d.classList.remove('error');
  }
}

function checkPin(){
  if(AGENT_PINS.includes(pinEntry)){
    // Succès
    attempts = 0;
    localStorage.removeItem('focus_attempts');
    localStorage.removeItem('focus_block');
    sessionStart = Date.now();
    sessionStorage.setItem('focus_agent_session', JSON.stringify({start:sessionStart}));
    // Flash vert
    for(let i=0;i<4;i++) document.getElementById('d'+i).style.background='#22C55E';
    setTimeout(showApp, 400);
  } else {
    // Échec
    attempts++;
    localStorage.setItem('focus_attempts', attempts);
    // Animer erreur
    for(let i=0;i<4;i++) document.getElementById('d'+i).classList.add('error');
    setTimeout(()=>{ pinEntry=''; updateDots(); },500);

    if(attempts >= MAX_ATTEMPTS){
      blockedUntil = Date.now() + BLOCK_MS;
      localStorage.setItem('focus_block', blockedUntil);
      showBlock();
    } else {
      const left = MAX_ATTEMPTS - attempts;
      showLoginErr(`Code incorrect. ${left} tentative${left>1?'s':''} restante${left>1?'s':''}.`);
      updateAttemptsLabel();
    }
  }
}

function showBlock(){
  const msg = document.getElementById('blocked-msg');
  const mins = Math.ceil((blockedUntil - Date.now()) / 60000);
  msg.style.display='block';
  msg.textContent=`⛔ Trop de tentatives. Accès bloqué pour ${mins} minute${mins>1?'s':''}.`;
  // Countdown
  const iv = setInterval(()=>{
    if(Date.now() >= blockedUntil){
      clearInterval(iv);
      blockedUntil=null;
      localStorage.removeItem('focus_block');
      attempts=0;
      localStorage.removeItem('focus_attempts');
      msg.style.display='none';
      updateAttemptsLabel();
    } else {
      const m = Math.ceil((blockedUntil-Date.now())/60000);
      msg.textContent=`⛔ Trop de tentatives. Accès bloqué pour ${m} minute${m>1?'s':''}.`;
    }
  },10000);
}

function updateAttemptsLabel(){
  const el = document.getElementById('attempts-txt');
  if(attempts>0) el.textContent = `${attempts}/${MAX_ATTEMPTS} tentatives`;
  else el.textContent='';
}
function showLoginErr(msg){ const e=document.getElementById('login-err'); e.textContent=msg; e.style.display='block'; }
function hideErr(){ document.getElementById('login-err').style.display='none'; }

function showApp(){
  document.getElementById('login-screen').style.display='none';
  document.getElementById('app').style.display='block';
  startSessionTimer();
  // Auto-vérifier si QR scanné en URL
  const params = new URLSearchParams(window.location.search);
  const token  = params.get('t');
  if(token){ const d=decodeToken(token); if(d) displayResult(d); }
}

function logout(){
  sessionStorage.removeItem('focus_agent_session');
  location.reload();
}

// ── Timer session
function startSessionTimer(){
  sessionTimer = setInterval(()=>{
    const elapsed = Date.now() - sessionStart;
    const remaining = SESSION_DURATION_MS - elapsed;
    if(remaining <= 0){ logout(); return; }
    const h = Math.floor(remaining/3600000);
    const m = Math.floor((remaining%3600000)/60000);
    document.getElementById('session-time').textContent =
      `Session expire dans ${h>0?h+'h ':''} ${m}min`;
  }, 30000);
  // Afficher immédiatement
  const h = Math.floor(SESSION_DURATION_MS/3600000);
  document.getElementById('session-time').textContent = `Session : ${h}h`;
}

// ══════════════════════════════════════════════
//  VÉRIFICATION BILLETS
// ══════════════════════════════════════════════
function isExpired(dateStr){
  try {
    const months = {
      'janvier':0,'février':1,'mars':2,'avril':3,'mai':4,'juin':5,
      'juillet':6,'août':7,'septembre':8,'octobre':9,'novembre':10,'décembre':11
    };
    const parts = dateStr.toLowerCase().replace(/,/g,'').split(/\s+/);
    let day, month, year;
    parts.forEach(p=>{
      const n = parseInt(p);
      if(!isNaN(n) && n>12 && n<32) day=n;
      if(months[p] !== undefined) month=months[p];
      if(!isNaN(n) && n>2000) year=n;
    });
    if(day && month!==undefined && year){
      return new Date() > new Date(year, month, day, 23, 59, 59);
    }
  } catch(e){}
  return false;
}

function decodeToken(raw){
  let token = raw.trim();
  if(token.includes('?t=')) token = token.split('?t=')[1].split('&')[0];
  try {
    return JSON.parse(decodeURIComponent(escape(atob(token))));
  } catch(e){ return null; }
}

function verifyManual(){
  const input = document.getElementById('ref-input').value.trim();
  if(!input){ showErr('Saisissez une référence ou collez les données QR.'); return; }
  const data = decodeToken(input);
  if(data && data.ref) displayResult(data);
  else if(input.startsWith('FOCUS-BK-')) displayRefOnly(input);
  else showErr('Données non reconnues. Collez les données du QR code ou une référence FOCUS-BK-...');
}

function displayResult(data){
  const expired = isExpired(data.date||'');
  const now = new Date().toLocaleString('fr-FR',{
    weekday:'short',day:'numeric',month:'long',
    hour:'2-digit',minute:'2-digit',second:'2-digit'
  });

  let html = '';

  if(!data.valid){
    html = `<div class="result-invalid">
      <div class="rh"><div class="rh-ico">❌</div><div class="rh-title">Billet INVALIDE</div><div class="rh-sub">Ce billet n'est pas reconnu ou a été falsifié</div></div>
      <div class="ticket-rows">
        <div class="tr"><span class="k">Référence</span><span class="v red">${data.ref||'—'}</span></div>
        <div class="tr"><span class="k">Statut</span><span class="v red">✕ Non valide — Refuser l'accès</span></div>
      </div>
    </div>`;
  } else if(expired){
    html = `<div class="result-expired">
      <div class="rh"><div class="rh-ico">⏰</div><div class="rh-title">Billet EXPIRÉ</div><div class="rh-sub">La date de ce trajet est passée</div></div>
      <div class="ticket-rows">
        <div class="tr"><span class="k">Référence</span><span class="v" style="font-family:monospace;font-size:12px">${data.ref}</span></div>
        <div class="tr"><span class="k">Passager</span><span class="v">${data.nom||'—'}</span></div>
        <div class="tr"><span class="k">Date trajet</span><span class="v orange">${data.date||'—'}</span></div>
        <div class="tr"><span class="k">Statut</span><span class="v orange">⏰ Expiré — Trajet passé</span></div>
      </div>
    </div>`;
  } else {
    html = `<div class="result-valid">
      <div class="rh"><div class="rh-ico">✅</div><div class="rh-title">Billet VALIDE</div><div class="rh-sub">Authentique · Laisser monter le passager</div></div>
      <div class="ticket-rows">
        <div class="tr"><span class="k">Référence</span><span class="v gold" style="font-family:monospace;font-size:12px">${data.ref}</span></div>
        <div class="tr"><span class="k">Passager</span><span class="v">${data.nom||'—'}</span></div>
        <div class="tr"><span class="k">Téléphone</span><span class="v">${data.tel||'—'}</span></div>
        <div class="tr"><span class="k">Date trajet</span><span class="v">${data.date||'—'}</span></div>
        <div class="tr"><span class="k">Prise en charge</span><span class="v">${data.lieu||'—'}</span></div>
        <div class="tr"><span class="k">Montant payé</span><span class="v gold">${data.montant||500} F CFA</span></div>
        <div class="tr"><span class="k">Statut</span><span class="v green">✓ Payé Wave — Valide</span></div>
        <div class="tr"><span class="k">Billet émis</span><span class="v" style="font-size:12px;color:#999">${data.issued?new Date(data.issued).toLocaleString('fr-FR'):'—'}</span></div>
      </div>
    </div>`;
  }

  document.getElementById('result-area').innerHTML = html;
  document.getElementById('ts').textContent = 'Contrôlé le ' + now;
  window.scrollTo(0,0);
}

function displayRefOnly(ref){
  document.getElementById('result-area').innerHTML = `
  <div class="result-expired">
    <div class="rh"><div class="rh-ico">⚠️</div><div class="rh-title">Vérification partielle</div><div class="rh-sub">Référence reconnue — scanner le QR pour vérification complète</div></div>
    <div class="ticket-rows">
      <div class="tr"><span class="k">Référence</span><span class="v" style="font-family:monospace">${ref}</span></div>
      <div class="tr"><span class="k">Info</span><span class="v orange">Scanner le QR code du billet physique</span></div>
    </div>
  </div>`;
}

function clearResult(){
  document.getElementById('result-area').innerHTML = `
  <div class="empty-state">
    <div class="empty-ico">🎫</div>
    <div class="empty-title">Prêt à vérifier</div>
    <div class="empty-sub">Scannez le QR code d'un billet FOCUS<br>ou collez les données ci-dessous</div>
  </div>`;
  document.getElementById('ref-input').value='';
  document.getElementById('ts').textContent='';
  hideAppErr();
}

function showErr(msg){ const e=document.getElementById('err-box'); e.textContent=msg; e.style.display='block'; }
function hideAppErr(){ document.getElementById('err-box').style.display='none'; }
function clearErr(){ hideAppErr(); }
</script>
</body>
</html>
